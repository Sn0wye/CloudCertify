{
  "openapi": "3.0.1",
  "info": {
    "title": "CloudCertify API",
    "description": "CloudCertify API — a cloud certification quiz and exam prep platform.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://0.0.0.0:8080"
    },
    {
      "url": "https://api-cloudcertify.snowye.dev",
      "description": "Production"
    }
  ],
