      "post": {
        "tags": ["Subquiz"],
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "subquizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
