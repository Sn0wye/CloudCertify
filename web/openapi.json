  },
  "components": {
    "schemas": {
      "AnswerDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string",
            "nullable": true
          },
          "image": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "DomainResult": {
        "required": ["domain", "correct", "total", "weight"],
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "correct": {
            "type": "integer",
            "format": "int32"
          },
          "total": {
            "type": "integer",
            "format": "int32"
          },
          "weight": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "QuestionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string",
            "nullable": true
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "selectCount": {
            "type": "integer",
            "format": "int32"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnswerDto"
            }
          }
        }
      },
      "QuestionType": {
        "enum": ["multiple_choice", "multiple_response"],
        "type": "string"
      },
      "QuizAnswer": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "integer",
            "format": "int32"
          },
          "answerIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      },
      "QuizDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "submissionId": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionDto"
            }
          }
        }
      },
      "QuizDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "iconName": {
            "type": "string"
          },
          "isAvailable": {
            "type": "boolean"
          },
          "quizProvider": {
            "$ref": "#/components/schemas/QuizProvider"
          },
          "quizLevel": {
            "$ref": "#/components/schemas/QuizLevel"
          },
          "slug": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "questionCount": {
            "type": "integer",
            "format": "int32"
          },
          "subQuizzes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubquizDto"
            },
            "nullable": true
          }
        }
      },
      "QuizLevel": {
        "enum": ["foundational", "associate", "professional", "specialist"],
        "type": "string"
      },
      "QuizProvider": {
        "enum": ["azure", "aws", "gcp"],
        "type": "string"
      },
      "QuizResultAnswerDto": {
        "required": ["id", "isCorrect", "wasSelected"],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string",
            "nullable": true
          },
          "image": {
            "type": "string",
            "nullable": true
          },
          "isCorrect": {
            "type": "boolean"
          },
          "wasSelected": {
            "type": "boolean"
          }
        }
      },
      "QuizResultQuestionDto": {
        "required": ["id", "text", "type", "answers"],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "domain": {
            "type": "string",
            "nullable": true
          },
          "concepts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "serviceCategory": {
            "type": "string",
            "nullable": true
          },
          "services": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "explanation": {
            "type": "string",
            "nullable": true
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuizResultAnswerDto"
            }
          }
        }
      },
      "StartQuizRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "SubmitQuizRequestDto": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "integer",
            "format": "int32"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuizAnswer"
            }
          }
        }
      },
      "SubmitQuizResponseDto": {
        "required": [
          "score",
          "totalQuestions",
          "correctCount",
          "scaledScore",
          "passed",
          "domainBreakdown",
          "questions"
        ],
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "format": "int32"
          },
          "totalQuestions": {
            "type": "integer",
            "format": "int32"
          },
          "correctCount": {
            "type": "integer",
            "format": "int32"
          },
          "scaledScore": {
            "type": "integer",
            "format": "int32"
          },
          "passed": {
            "type": "boolean"
          },
          "domainBreakdown": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DomainResult"
            }
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuizResultQuestionDto"
            }
          }
        }
      },
      "SubquizDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "submissionId": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionDto"
            }
          }
        }
      },
      "SubquizDto": {
        "required": ["id", "title", "domain", "slug", "isAvailable"],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "isAvailable": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Quiz"
    },
    {
      "name": "Subquiz"
    }
  ]
}
