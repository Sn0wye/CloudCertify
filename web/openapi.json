{
  "openapi": "3.0.1",
  "info": {
    "title": "CloudCertify API",
    "description": "CloudCertify API — a cloud certification quiz and exam prep platform.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://0.0.0.0:8080"
    },
    {
      "url": "https://api-cloudcertify.snowye.dev",
      "description": "Production"
    }
  ],
  "paths": {
    "/quiz": {
      "get": {
        "tags": ["Quiz"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QuizDto"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QuizDto"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QuizDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/quiz/{quizId}": {
      "get": {
        "tags": ["Quiz"],
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              }
            }
          }
        }
      }
    },
    "/quiz/{quizId}/start": {
      "post": {
        "tags": ["Quiz"],
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartQuizRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartQuizRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartQuizRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuizDetailDto"
                }
              }
            }
          }
        }
      }
    },
    "/quiz/{quizId}/submit": {
      "post": {
        "tags": ["Quiz"],
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitQuizRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitQuizRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitQuizRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitQuizResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitQuizResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitQuizResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/quiz/process": {
      "post": {
        "tags": ["Quiz"],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Answer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "questionId": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Question": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "quizId": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/QuestionType"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Answer"
            }
          }
        }
      },
      "QuestionType": {
        "enum": ["multiple_choice", "true_false"],
        "type": "string"
      },
      "QuizAnswer": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "integer",
            "format": "int32"
          },
          "answerId": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "QuizDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "submissionId": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Question"
            }
          }
        }
      },
      "QuizDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "iconName": {
            "type": "string"
          },
          "isAvailable": {
            "type": "boolean"
          },
          "quizProvider": {
            "$ref": "#/components/schemas/QuizProvider"
          },
          "quizLevel": {
            "$ref": "#/components/schemas/QuizLevel"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "questionCount": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "QuizLevel": {
        "enum": ["foundational", "associate", "professional", "specialist"],
        "type": "string"
      },
      "QuizProvider": {
        "enum": ["azure", "aws", "gcp"],
        "type": "string"
      },
      "StartQuizRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "SubmitQuizRequestDto": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "integer",
            "format": "int32"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuizAnswer"
            }
          }
        }
      },
      "SubmitQuizResponseDto": {
        "required": ["score"],
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Quiz"
    }
  ]
}
